#: data/xfce/xfce-accessories.desktop.in:6
msgid "Accessories"
msgstr "ເຄື່ອງໃຊ້ສອຍ"

#: data/xfce/xfce-accessories.desktop.in:7
msgid "Common desktop tools and applications"
msgstr "ເຄື່ອງມື ແລະ ແອັບພລິເຄຊັນພື້ນຖານຂອງເດດທັອບ"

#: data/xfce/xfce-development.desktop.in:6
msgid "Development"
msgstr "ການພັດທະນາ"

#: data/xfce/xfce-development.desktop.in:7
msgid "Software development tools"
msgstr "ເຄື່ອງມືພັດທະນາຊອບແວ"

#: data/xfce/xfce-education.desktop.in:6
msgid "Education"
msgstr "ການສຶກສາ"

#: data/xfce/xfce-education.desktop.in:7
msgid "Educational software"
msgstr "ຊອບແວການສຶກສາ"

#: data/xfce/xfce-games.desktop.in:6
msgid "Games"
msgstr "ເກມ"

#: data/xfce/xfce-games.desktop.in:7
msgid "Games, puzzles, and other fun software"
msgstr "ເກມ, ປິດສະໜາ, ແລະ ຊອບແວຄວາມບັນເທີງອື່ນໆ"

#: data/xfce/xfce-graphics.desktop.in:6
msgid "Graphics"
msgstr "ກຣາຟິກ"

#: data/xfce/xfce-graphics.desktop.in:7
msgid "Graphics creation and manipulation applications"
msgstr "ແອັບພລິເຄຊັນສ້າງ ແລະ ຈັດການກຣາຟິກ"

#: data/xfce/xfce-hardware.desktop.in:6
msgid "Hardware"
msgstr "ຮາດແວ"

#: data/xfce/xfce-hardware.desktop.in:7
msgid "Settings for several hardware devices"
msgstr "ການຕັ້ງຄ່າສຳລັບອຸປະກອນຮາດແວຕ່າງໆ"

#: data/xfce/xfce-health.desktop.in:6
msgid "Health"
msgstr "ສຸຂະພາບ"

#: data/xfce/xfce-health.desktop.in:7
msgid "Applications related to physical or mental health and fitness"
msgstr "ແອັບພລິເຄຊັນທີ່ກ່ຽວຂ້ອງກັບສຸຂະພາບທາງກາຍ ຫຼື ທາງຈິດ ແລະ ການອອກກຳລັງກາຍ"

#: data/xfce/xfce-multimedia.desktop.in:6
msgid "Multimedia"
msgstr "ມັລຕິມີເດຍ"

#: data/xfce/xfce-multimedia.desktop.in:7
msgid "Audio and video players and editors"
msgstr "ເຄື່ອງຫຼິ້ນ ແລະ ເຄື່ອງມືແກ້ໄຂສຽງ ແລະ ວິດີໂອ"

#: data/xfce/xfce-network.desktop.in:6
msgid "Internet"
msgstr "ອິນເຕີເນັດ"

#: data/xfce/xfce-network.desktop.in:7
msgid "Applications for Internet access"
msgstr "ແອັບພລິເຄຊັນສຳລັບການເຂົ້າເຖິງອິນເຕີເນັດ"

#: data/xfce/xfce-office.desktop.in:6
msgid "Office"
msgstr "ສຳນັກງານ"

#: data/xfce/xfce-office.desktop.in:7
msgid "Office and productivity applications"
msgstr "ແອັບພລິເຄຊັນສຳນັກງານ ແລະ ການເພີ່ມຜົນຜະລິດ"

#: data/xfce/xfce-other.desktop.in:6
msgid "Other"
msgstr "ອື່ນໆ"

#: data/xfce/xfce-other.desktop.in:7
msgid "Applications that don't fit into other categories"
msgstr "ແອັບພລິເຄຊັນທີ່ບໍ່ຈັດຢູ່ໃນໝວດໝູ່ອື່ນ"

#: data/xfce/xfce-personal.desktop.in:6
msgid "Personal"
msgstr "ສ່ວນຕົວ"

#: data/xfce/xfce-personal.desktop.in:7
msgid "Personal settings"
msgstr "ການຕັ້ງຄ່າສ່ວນຕົວ"

#: data/xfce/xfce-science.desktop.in:6
msgid "Science"
msgstr "ວິທະຍາສາດ"

#: data/xfce/xfce-science.desktop.in:7
msgid "Scientific software"
msgstr "ຊອບແວວິທະຍາສາດ"

#: data/xfce/xfce-screensavers.desktop.in:6
msgid "Screensavers"
msgstr "ໂປຣແກຣມຮັກສາໜ້າຈໍ"

#: data/xfce/xfce-screensavers.desktop.in:7
msgid "Screensaver applets"
msgstr "ແອັບເປັດຮັກສາໜ້າຈໍ"

#: data/xfce/xfce-settings.desktop.in:6
msgid "Settings"
msgstr "ການຕັ້ງຄ່າ"

#: data/xfce/xfce-settings.desktop.in:7
msgid "Desktop and system settings applications"
msgstr "ແອັບພລິເຄຊັນຕັ້ງຄ່າເດດທັອບ ແລະ ລະບົບ"

#: data/xfce/xfce-system.desktop.in:6
msgid "System"
msgstr "ລະບົບ"

#: data/xfce/xfce-system.desktop.in:7
msgid "System tools and utilities"
msgstr "ເຄື່ອງມື ແລະ ຢູທິລິຕີ້ຂອງລະບົບ"

#: garcon/garcon-menu.c:747
#, c-format
msgid "File \"%s\" not found"
msgstr "ບໍ່ພົບໄຟລ໌ \"%s\""

#: garcon/garcon-menu-parser.c:282
#, c-format
msgid "Could not load menu file data from %s: %s"
msgstr "ບໍ່ສາມາດໂຫຼດຂໍ້ມູນໄຟລ໌ເມນູຈາກ %s: %s"

#: garcon/garcon-menu-parser.c:289
#, c-format
msgid "Could not load menu file data from %s"
msgstr "ບໍ່ສາມາດໂຫຼດຂໍ້ມູນໄຟລ໌ເມນູຈາກ %s"

#: garcon-gtk/garcon-gtk-menu.c:424
#, c-format
msgid "Failed to execute command \"%s\"."
msgstr "ບໍ່ສາມາດປະຕິບັດຄຳສັ່ງ \"%s\"."

#: garcon-gtk/garcon-gtk-menu.c:450
msgid "Launch Error"
msgstr "ເກີດຂໍ້ຜິດພາດໃນການເປີດ"

#: garcon-gtk/garcon-gtk-menu.c:451
msgid ""
"Unable to launch \"xfce-desktop-item-edit\", which is required to create and"
" edit menu items."
msgstr "ບໍ່ສາມາດເປີດໃຊ້ງານ \"xfce-desktop-item-edit\", ເຊິ່ງຈຳເປັນຕ້ອງໃຊ້ເພື່ອສ້າງ ແລະ ແກ້ໄຂລາຍການເມນູ."

#: garcon-gtk/garcon-gtk-menu.c:452
msgid "_Close"
msgstr "_ປິດ"

#: garcon-gtk/garcon-gtk-menu.c:601
msgid "Failed to load the applications menu"
msgstr "ໂຫຼດເມນູແອັບພລິເຄຊັນບໍ່ສຳເລັດ"
